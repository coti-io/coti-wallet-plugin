VITE_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id_here

# Local snap dev (npm run dev:local-snap sets VITE_SNAP_ID automatically).
# VITE_SNAP_ID=local:http://localhost:8080
# VITE_SNAP_VERSION=1.0.52

# Fully disable COTI Snap in the example app (install, probe, and key use). Default: true
# VITE_COTI_SNAP_ENABLED=false

# Encrypted AES backups in the example are stored in localStorage only
# (key: coti-example:aes-backup:<chainId>:<address>).

# Native COTI grant during onboarding. Default: true
# Set false to skip grant requests (wallet must already have gas).
# VITE_ONBOARDING_GRANT_ENABLED=false

# Grant API endpoints.
# Testnet defaults to the official COTI grant API when unset.
# Expected route:
#   POST / with { "address": string, "chainId": number }
# VITE_GRANT_API_URL_TESTNET=https://testnet-apps-1-gw.coti.io/cms-coti-2bb8/api/v1/gas-grant
# VITE_GRANT_API_URL_MAINNET=https://mainnet.example.com/grant

# Native COTI balance threshold before requesting a grant. Default: 0.2
# VITE_ONBOARDING_GRANT_MIN_BALANCE_COTI=0.2
