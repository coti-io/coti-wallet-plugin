{
  "name": "@coti-io/coti-wallet-plugin",
  "version": "0.2.4",
  "description": "COTI Wallet Plugin — high-level abstraction for Private Token (pToken) operations across EIP-1193 wallets",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/coti-io/coti-wallet-plugin.git"
  },
  "homepage": "https://github.com/coti-io/coti-wallet-plugin#readme",
  "bugs": {
    "url": "https://github.com/coti-io/coti-wallet-plugin/issues"
  },
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "docs",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write 'src/**/*.{ts,tsx}' 'tests/**/*.{ts,tsx}'",
    "format:check": "prettier --check 'src/**/*.{ts,tsx}' 'tests/**/*.{ts,tsx}'",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run typecheck && npm test -- --run && npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "coti",
    "wallet",
    "privacy",
    "ptoken",
    "erc20",
    "metamask",
    "snap",
    "bridge"
  ],
  "author": "COTI",
  "license": "Apache 2.0",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22.15.0"
  },
  "packageManager": "npm@11.9.0",
  "dependencies": {
    "@coti-io/coti-ethers": "^1.0.0",
    "@coti-io/pod-sdk": "^0.1.3"
  },
  "peerDependencies": {
    "@coti-io/coti-sdk-typescript": "^1.0.8",
    "@metamask/providers": "^22.0.0",
    "@rainbow-me/rainbowkit": "^2.0.0",
    "@tanstack/react-query": "^5.0.0",
    "ethers": "^6.0.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "viem": "^2.0.0",
    "wagmi": "^2.0.0"
  },
  "devDependencies": {
    "@coti-io/coti-sdk-typescript": "^1.0.8",
    "@eslint/js": "^10.0.1",
    "@metamask/providers": "^22.1.1",
    "@rainbow-me/rainbowkit": "^2.2.0",
    "@tanstack/react-query": "^5.62.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^14.3.1",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.7",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^10.4.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "ethers": "^6.16.0",
    "happy-dom": "^20.9.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsup": "^8.0.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.61.0",
    "viem": "^2.47.10",
    "vitest": "^4.1.8",
    "wagmi": "^2.14.0"
  }
}
