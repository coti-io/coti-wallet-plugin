{
  "name": "@coti-io/coti-wallet-plugin",
  "version": "0.1.0",
  "description": "COTI Wallet Plugin — high-level abstraction for Private Token (pToken) operations across EIP-1193 wallets",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "coti",
    "wallet",
    "privacy",
    "ptoken",
    "erc20",
    "metamask",
    "snap",
    "bridge"
  ],
  "author": "COTI",
  "license": "Apache-2.0",
  "dependencies": {
    "@coti-io/coti-ethers": "^1.0.0"
  },
  "peerDependencies": {
    "@coti-io/coti-sdk-typescript": "^1.0.6",
    "@metamask/providers": "^22.0.0",
    "@rainbow-me/rainbowkit": "^2.0.0",
    "@tanstack/react-query": "^5.0.0",
    "ethers": "^6.0.0",
    "react": "^18.0.0",
    "viem": "^2.0.0",
    "wagmi": "^2.0.0"
  },
  "devDependencies": {
    "@coti-io/coti-sdk-typescript": "^1.0.6",
    "@metamask/providers": "^22.1.1",
    "@rainbow-me/rainbowkit": "^2.2.0",
    "@tanstack/react-query": "^5.62.0",
    "@types/react": "^18.3.18",
    "ethers": "^6.16.0",
    "react": "^18.3.1",
    "tsup": "^8.0.0",
    "typescript": "~5.9.3",
    "viem": "^2.47.10",
    "wagmi": "^2.14.0"
  }
}
