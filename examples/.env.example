VITE_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id_here

# Local snap dev (npm run dev:local-snap sets VITE_SNAP_ID automatically).
# VITE_SNAP_ID=local:http://localhost:8080
# VITE_SNAP_VERSION=1.0.52

# On-chain AES backup vault for onboarding backup save/restore.
VITE_AES_KEY_BACKUP_VAULT_ADDRESS=0x9d56c9Beca9D9a61fFf100104864445ad78579f1

# Optional native COTI grant APIs.
# If unset, no grant is requested; onboarding requires the wallet to already
# have enough native COTI for gas.
# Expected route:
#   POST / with { "address": string, "chainId": number }
# VITE_GRANT_API_URL_TESTNET=https://testnet.example.com/grant
# VITE_GRANT_API_URL_MAINNET=https://mainnet.example.com/grant

# Native COTI balance threshold before requesting a grant.
# VITE_ONBOARDING_GRANT_MIN_BALANCE_COTI=0.2
